<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <style>
    body {
      background: #0a0a0a;
      color: #ccc;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      min-height: 100vh;
      font-family: monospace;
    }
    table {
      border-collapse: collapse;
      margin: 40px 0 20px;
    }
    td {
      width: 60px;
      height: 60px;
      text-align: center;
      font-size: 28px;
      font-weight: bold;
      border: 1px solid #333;
      color: #eee;
    }
    p {
      font-size: 13px;
      color: #555;
      letter-spacing: 3px;
      margin-top: 20px;
    }
  </style>
</head>
<body>
  <table>
    <tr><td>T</td><td>Y</td><td>L</td></tr>
    <tr><td>E</td><td>C</td><td>L</td></tr>
    <tr><td>E</td><td>B</td><td>H</td></tr>
  </table>
</body>
</html>
